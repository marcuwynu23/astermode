{
  "name": "astermode",
  "version": "1.0.0",
  "description": "A Vite plugin that injects a draggable Dev Mode overlay during development.",
  "type": "module",
  "scripts": {
    "check:exports": "node --input-type=module -e \"import('./src/astermode.js').then((m)=>{if(typeof m.default!=='function') throw new Error('default export is not a function'); console.log('default export ok');})\"",
    "pack:check": "npm pack --dry-run"
  },
  "main": "./src/astermode.js",
  "module": "./src/astermode.js",
  "types": "./src/astermode.d.ts",
  "exports": {
    ".": {
      "types": "./src/astermode.d.ts",
      "import": "./src/astermode.js",
      "default": "./src/astermode.js"
    }
  },
  "files": [
    "src/astermode.js",
    "src/astermode.d.ts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "vite",
    "vite-plugin",
    "devtools",
    "overlay",
    "frontend"
  ],
  "author": "Mark Wayne Menorca",
  "repository": {
    "type": "git",
    "url": "https://github.com/marcuwynu23/AsterMode.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
